# laCalle OS — variables de entorno
# Copia este archivo como ".env.local" y completa con los datos de tu proyecto Supabase.
# Mientras estas variables estén vacías, la app corre en modo LOCAL (localStorage).
# En cuanto las completes (y haya login), la app guarda en Supabase automáticamente.

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Solo para operaciones de administración del lado del servidor (Fase 3).
# NUNCA le pongas el prefijo NEXT_PUBLIC: no debe llegar al navegador.
SUPABASE_SERVICE_ROLE_KEY=
